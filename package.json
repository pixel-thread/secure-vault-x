{
  "name": "securevault-x",
  "private": true,
  "scripts": {
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "build": "pnpm -r build",
    "generate": "pnpm -r generate",
    "eas-build-pre-install": "pnpm install --frozen-lockfile",
    "eas-build-post-install": "pnpm run build && pnpm run generate"
  },
  "devDependencies": {
    "turbo": "latest",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@10.0.0",
  "pnpm": {
    "overrides": {
      "react": "19.1.0",
      "react-dom": "19.1.0",
      "react-native": "0.81.5",
      "expo": "^54.0.0",
      "@expo/vector-icons": "^15.0.2",
      "expo-font": "14.0.11",
      "expo-constants": "~18.0.9",
      "expo-secure-store": "~15.0.8",
      "expo-asset": "~12.0.12",
      "expo-file-system": "~19.0.21",
      "expo-keep-awake": "~15.0.8",
      "expo-modules-core": "~3.0.29"
    }
  }
}
