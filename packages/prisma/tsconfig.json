{
  "extends": "@securevault/typescript-config/node.json",
  "compilerOptions": {
    "declaration": true,
    "outDir": "dist",
    "rootDir": "src",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "target": "ES2020"
  },
  "include": [
    "src",
    "src/generated/prisma"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}