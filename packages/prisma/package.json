{
  "name": "@securevault/database",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "migrate": "prisma migrate dev --schema=src/schema.prisma",
    "push": "prisma db push --schema=src/schema.prisma",
    "build": "tsc && cp -r src/generated dist/",
    "lint": "eslint .",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy"
  },
  "dependencies": {
    "@prisma/client": "7.0.0",
    "@prisma/adapter-pg": "7.0.0",
    "pg": "^8.0.0",
    "dotenv": "^16.0.0"
  },
  "devDependencies": {
    "@securevault/eslint-config": "workspace:*",
    "@securevault/typescript-config": "workspace:*",
    "prisma": "7.0.0",
    "typescript": "^5.3.3",
    "@types/pg": "^8.0.0"
  }
}
