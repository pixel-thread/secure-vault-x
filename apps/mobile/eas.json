{
  "build": {
    "development": {
      "android": {
        "buildType": "apk"
      },
      "distribution": "internal",
      "channel": "development",
      "cache": {
        "key": "android-cache-v1",
        "paths": [
          "android/.gradle",
          "~/.gradle/caches",
          "~/.gradle/wrapper",
          "~/.pnpm-store",
          "~/.expo"
        ]
      }
    },
    "preview": {
