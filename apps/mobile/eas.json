{
  "cli": {
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "android": { "buildType": "apk" },
      "channel": "development",
      "distribution": "internal",
      "developmentClient": true,
      "env": {
        "APP_VARIANT": "development"
      }
    },
    "preview": {
      "android": { "buildType": "apk" },
      "distribution": "internal",
      "channel": "preview",
      "env": {
        "APP_VARIANT": "preview"
      },
      "cache": {
        "key": "android-cache-v2",
        "paths": ["android/.gradle"]
      }
    },
    "production": {
      "android": { "buildType": "apk" },
      "channel": "production",
      "env": { "APP_VARIANT": "production" },
      "cache": {
        "key": "android-cache-v2",
        "paths": ["android/.gradle"]
      }
    }
  }
}
