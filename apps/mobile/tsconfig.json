{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@src/*": ["src/*"],
      "@components/*": ["src/components/*"],
      "@hooks/*": ["src/hooks/*"],
      "@libs/*": ["src/libs/*"],
      "@database/*": ["src/libs/database/*"],
      "@utils/*": ["src/utils/*"],
      "@store/*": ["src/store/*"],
      "@types/*": ["src/types/*"],
      "@services/*": ["src/services/*"],
      "@securevault/constants": ["../../packages/constants/src"],
      "@securevault/crypto": ["../../packages/crypto/src"],
      "@securevault/libs": ["../../packages/libs/src"],
      "@securevault/types": ["../../packages/types/src"],
      "@securevault/ui-native": ["../../packages/ui-native/src"],
      "@securevault/utils": ["../../packages/utils/src"],
      "@securevault/utils-native": ["../../packages/utils-native/src"],
      "@securevault/validators": ["../../packages/validators/src"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx", ".expo/types/**/*.ts", "expo-env.d.ts", "nativewind-env.d.ts"]
}
