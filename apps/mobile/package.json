{
  "name": "@securevault/mobile",
  "version": "0.0.7",
  "main": "expo-router/entry",
  "scripts": {
    "build:local:android": "eas build --profile development --platform android --local",
    "build:preview:android": "eas build --profile preview --platform android --local",
    "build:prod:android": "eas build --profile production --platform android --local",
    "start": "expo start",
    "dev": "expo start -c",
    "prebuild": "expo prebuild",
    "lint": "eslint \"**/*.{js,jsx,ts,tsx}\" && prettier -c \"**/*.{js,jsx,ts,tsx,json}\"",
    "format": "eslint \"**/*.{js,jsx,ts,tsx}\" --fix && prettier \"**/*.{js,jsx,ts,tsx,json}\" --write",
    "db:generate": "drizzle-kit generate",
    "android": "expo run:android",
    "ios": "expo run:ios"
  },
