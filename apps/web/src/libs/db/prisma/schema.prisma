generator client {
  provider = "prisma-client-js"
  output   = "./generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String?
  mfaEnabled   Boolean  @default(false)
  createdAt    DateTime @default(now())

  credentials      WebAuthnCredential[]
  devices          Device[]
  refreshTokens    RefreshToken[]
  otpVerifications OtpVerification[]
  encryption       UserEncryption?
  auditLogs        AuditLog[]
  vaults           Vault[]
}

model UserEncryption {
  id        String   @id @default(uuid())
  userId    String   @unique
  salt      String // Base64 encoded salt for Argon2 MEK generation
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model WebAuthnCredential {
  id           String @id @default(uuid())
  userId       String
  credentialId String @unique
  publicKey    Bytes
  counter      BigInt
  transports   String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Device {
  id               String   @id @default(uuid())
  userId           String
  deviceIdentifier String? // Hardware UUID or persistent device ID
  deviceName       String
  publicKey        String? // Base64 encoded ECDSA P-256 SPKI public key
  encryptedMEK     String?
  isTrusted        Boolean  @default(false)
  createdAt        DateTime @default(now())

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  refreshTokens RefreshToken[]

  @@unique([userId, deviceIdentifier])
}

model Vault {
  id            String    @id @default(uuid())
  userId        String
  encryptedData String
  iv            String?
  version       BigInt    @default(1)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([id])
  @@index([userId, iv])
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  deviceId  String?
  tokenHash String   @unique // Hashed token
  expiresAt DateTime
  revoked   Boolean  @default(false)

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  device Device? @relation(fields: [deviceId], references: [id], onDelete: Cascade)
}

model OtpVerification {
  id        String    @id @default(uuid())
  userId    String
  code      String
  type      String // e.g. "EMAIL_LOGIN"
  expiresAt DateTime
  isRevoked Boolean   @default(false)
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  action    String // e.g. "LOGIN_SUCCESS", "MFA_TOGGLE", "VAULT_SYNC"
  metadata  Json? // Optional extra data (e.g. device ID, IP)
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)
}

enum ErrorType {
  ERROR
  WARN
  INFO
  LOG
}

model Log {
  id        String    @id @default(uuid())
  type      ErrorType // 'ERROR', 'INFO', 'WARN', or 'LOG'
  content   String // The log message; can store stringified JSON
  isBackend Boolean   @default(false)
  message   String
  timestamp DateTime  @default(now()) // When the log was created

  @@index([isBackend, timestamp])
  @@index([type, timestamp])
  @@index([timestamp])
}

enum EASBuildStatus {
  FINISHED
  ERRORED
  CANCELED
}

enum AppVersionPlatform {
  ANDROID
  IOS
}

enum AppVersionTags {
  BETA
  STABLE
  BUGFIX
  PATCH
}

enum AppVersionType {
  PTA
  OTA
}

enum Status {
  ACTIVE
  INACTIVE
  DELETED
}

enum EASWebhookType {
  BUILD
  UPDATE
  SUBMIT
}

model EASWebhook {
  id             String              @id @default(uuid()) @db.Uuid
  easId          String              @unique // EAS build/update/submit id
  type           EASWebhookType
  accountName    String
  projectName    String
  appId          String?
  platform       AppVersionPlatform?
  status         EASBuildStatus
  detailsPageUrl String?

  // Artifacts (Build specific)
  buildUrl        String?
  logsS3KeyPrefix String?

  // Metadata subset (Build/Update specific)
  appVersion       String?
  appBuildVersion  String?
  buildProfile     String?
  distribution     String?
  runtimeVersion   String?
  channel          String?
  gitCommitHash    String?
  gitCommitMessage String?

  // Update specific
  updateMessage String?
  branch        String?

  // Timestamps
  createdAt   DateTime
  enqueuedAt  DateTime?
  completedAt DateTime?

  // Error info
  errorMessage String?
  errorCode    String?

  // Full payload
  rawPayload Json

  @@index([platform])
  @@index([status])
  @@index([type])
  @@index([completedAt])
}

model AppVersion {
  version             String               @unique
  title               String
  description         String[]
  type                AppVersionType       @default(PTA)
  platforms           AppVersionPlatform[] @default([ANDROID, IOS])
  releaseNotesUrl     String?
  downloadUrl         String?
  releaseDate         DateTime             @default(now())
  minSupportedVersion String?
  author              String?
  tags                AppVersionTags[]     @default([STABLE])
  additionalInfo      Json?
  status              Status               @default(ACTIVE)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  versionCode    Int?
  buildNumber    String?
  runtimeVersion String?

  @@index([version])
}
