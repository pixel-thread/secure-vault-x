    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.36.4",
    "bcryptjs": "^3.0.3",
    "dotenv": "^16.0.0",
    "ioredis": "^5.10.0",
    "jose": "^6.1.3",
    "lucide-react": "^0.575.0",
    "next": "16.1.6",
