{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "globalEnv": ["DATABASE_URL"],
  "tasks": {
    "generate": {
      "dependsOn": ["^generate"]
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**"]
    },
    "lint": {},
    "format": {
      "dependsOn": ["^format"]
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "env": [
        "EXPO_PUBLIC_API_URL",
        "RP_ID",
        "RP_NAME",
        "JWT_SECRET",
        "NODE_ENV",
        "EXPECTED_ORIGIN",
        "ALLOWED_ORIGINS"
      ]
    },
    "db:generate": {
      "cache": false
    },
    "db:migrate": {
      "cache": false
    },
    "db:deploy": {
      "cache": false
    }
  }
}
