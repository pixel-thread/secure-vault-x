{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "generate": {
      "dependsOn": ["^generate"]
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**"]
    },
    "lint": {},
    "dev": {
      "cache": false,
      "persistent": true,
      "env": [
        "RP_ID",
        "RP_NAME",
        "JWT_SECRET",
        "NODE_ENV",
        "NODE_OPTIONS",
        "EXPECTED_ORIGIN",
        "NODE_ENV"
      ]
    }
  }
}
